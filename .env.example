APP_NAME="Programa Agrario"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080
APP_PORT=8080

LOG_CHANNEL=stack
LOG_LEVEL=debug

# Base de datos
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_PORT_EXTERNAL=5432
DB_DATABASE=agrario
DB_USERNAME=agrario
DB_PASSWORD=secret

# Redis (caché y colas)
CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PORT_EXTERNAL=6379

# Correo (configura según tu proveedor)
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_FROM_ADDRESS=noreply@agrario.local
MAIL_FROM_NAME="${APP_NAME}"

# Almacenamiento
FILESYSTEM_DISK=local

# MinIO (opcional, descomenta si activas el servicio)
# MINIO_ACCESS_KEY=agrario
# MINIO_SECRET_KEY=secretminio
# AWS_ENDPOINT=http://minio:9000
# AWS_BUCKET=agrario
